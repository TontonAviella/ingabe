# Production build environment for the Vite-built SPA.
#
# WARNING: Vite bakes VITE_* values into the compiled JS bundle at build
# time. Whatever you put here ends up in production users' browsers.
# Never commit secrets, but also never use dev keys in prod — a pk_test_*
# Clerk key in here will literally ship the dev key to every prod visitor.
#
# Copy this file to frontendts/.env.production on the build host before
# `npm run build`. The .env.production file is gitignored and stays
# host-local.

# Clerk publishable key. Must be pk_live_* in production.
# Find this in the Clerk Dashboard → Configure → API Keys → Production.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Satellite frontend-API host. When a partner runs Clerk on their own
# subdomain (e.g. clerk.nozalabs.rw), set this to that host so the SDK
# fetches /.well-known/jwks.json + sign-in scripts from it instead of
# *.clerk.accounts.dev.
# Coordinate with `CLERK_FRONTEND_API_HOST` in /home/deploy/mundi.ai/.env
# (the backend CSP allowlist reads the same value via src/wsgi.py).
VITE_CLERK_FRONTEND_API_HOST=clerk.nozalabs.rw

# Satellite sign-in / sign-up URLs. Default to the satellite host; switch
# to /sign-in / /sign-up paths if you host Clerk's hosted-pages mode on
# your own domain.
VITE_CLERK_SIGN_IN_URL=https://clerk.nozalabs.rw/sign-in
VITE_CLERK_SIGN_UP_URL=https://clerk.nozalabs.rw/sign-up
VITE_CLERK_AFTER_SIGN_IN_URL=/
VITE_CLERK_AFTER_SIGN_UP_URL=/

# PostHog product-analytics key (project key, safe to expose — distinct
# from the admin pk_phx_* personal API key which must NEVER be in here).
VITE_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Mapbox / MapTiler / etc. — none in default mundi.ai builds, add per partner.
