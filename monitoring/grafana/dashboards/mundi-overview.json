{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_request_errors_total[5m])",
          "legendFormat": "err/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.1 }] } }
      }
    },
    {
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "http_requests_active",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "http_request_duration_seconds_avg",
          "legendFormat": "avg",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "db_pool_size", "legendFormat": "write pool size", "refId": "A" },
        { "expr": "db_pool_free", "legendFormat": "write pool free", "refId": "B" },
        { "expr": "db_pool_max", "legendFormat": "write pool max", "refId": "C" },
        { "expr": "db_read_pool_size", "legendFormat": "read pool size", "refId": "D" },
        { "expr": "db_read_pool_free", "legendFormat": "read pool free", "refId": "E" }
      ]
    },
    {
      "title": "HTTP Requests Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "rate(http_requests_total[1m])", "legendFormat": "requests/s", "refId": "A" },
        { "expr": "rate(http_request_errors_total[1m])", "legendFormat": "errors/s", "refId": "B" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["mundi", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Mundi.ai Overview",
  "uid": "mundi-overview"
}
