# =============================================================
# Mundi.ai — Production environment variables
# Copy to .env.prod and fill in real values before deploying.
#   cp .env.prod.example .env.prod
# =============================================================

# ---- Domain ----
VITE_WEBSITE_DOMAIN=https://gis.nozalabs.rw

# ---- Database ----
POSTGRES_USER=mundiuser
POSTGRES_PASSWORD=<generate-with: openssl rand -base64 32>
POSTGRES_DB=mundidb
POSTGRES_HOST=postgresdb
POSTGRES_PORT=5432

# ---- MinIO / S3 ----
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=<generate-with: openssl rand -base64 32>
S3_ACCESS_KEY_ID=s3user
S3_SECRET_ACCESS_KEY=<generate-with: openssl rand -base64 32>
S3_DEFAULT_REGION=us-east-1
S3_ENDPOINT_URL=https://s3.gis.nozalabs.rw
S3_BUCKET=noza

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- App performance ----
WEB_CONCURRENCY=4
DB_POOL_MAX_SIZE=15

# ---- Clerk authentication (copy from Render dashboard) ----
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_ISSUER=

# ---- OpenAI / LLM ----
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-nano

# ---- Sentinel Hub / Planet Labs (copy from Render dashboard) ----
SH_CLIENT_ID=
SH_CLIENT_SECRET=

# ---- OpenEO ----
OPENEO_CLIENT_ID=
OPENEO_CLIENT_SECRET=

# ---- Copernicus CDS ----
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=

# ---- Frontend build args ----
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_SIGN_IN_URL=
VITE_CLERK_SIGN_UP_URL=
VITE_POSTHOG_KEY=phc_W7tOZXWc5oPtpiYyyINii49GodL1NgyS6z30pNW8aTP
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ---- Observability (optional — HyperDX, Grafana Cloud, etc.) ----
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=ingabe

# ---- Rate limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_EXPENSIVE=20/minute
RATE_LIMIT_HEAVY=10/minute
RATE_LIMIT_GENERAL=120/minute

# ---- Backups ----
BACKUP_RETENTION_DAYS=7
BACKUP_CRON=0 2 * * *
