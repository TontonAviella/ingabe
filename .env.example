# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Clerk authentication ----
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_ISSUER=

# ---- OpenAI / LLM ----
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-nano

# ---- Sentinel Hub ----
SH_CLIENT_ID=
SH_CLIENT_SECRET=

# ---- OpenEO ----
OPENEO_CLIENT_ID=
OPENEO_CLIENT_SECRET=

# ---- Copernicus CDS ----
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=

# ---- Frontend build args ----
VITE_WEBSITE_DOMAIN=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_SIGN_IN_URL=
VITE_CLERK_SIGN_UP_URL=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=ingabe

# ---- Rate limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_EXPENSIVE=20/minute
RATE_LIMIT_HEAVY=10/minute
RATE_LIMIT_GENERAL=120/minute

# ---- Database backups ----
BACKUP_RETENTION_DAYS=7
BACKUP_CRON=0 2 * * *

# ---- Superset ----
SUPERSET_SECRET_KEY=changeme
